# ============================================
# HD Mart - Smart Grocery E-Commerce Platform
# Root .gitignore
# ============================================

# ---- Environment Variables (NEVER commit these) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env

# ---- Node Modules ----
node_modules/
client/node_modules/
server/node_modules/

# ---- Build Output ----
client/dist/
client/build/
server/dist/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo

# ---- Cache ----
.cache/
.parcel-cache/
.vite/

# ---- Coverage ----
coverage/
.nyc_output/

# ---- Misc ----
*.tgz
*.zip
